rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ── Commerces : lecture pour tout utilisateur authentifié,
          écriture réservée aux admins (custom claim).
          Le compte caisse lié (storeUid) peut en plus modifier SES
          PROPRES règles métier (multiStamp, dailyLimit) depuis la
          Console Caisse — et uniquement ces deux champs. ── */
    match /commerces/{commerceId} {
      allow read : if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.admin == true;

      /* Réglages "Console Caisse" modifiables par le staff lié */
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.storeUid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['multiStamp', 'dailyLimit']);

      /* Journal d'activité (tampons / récompenses) — alimente le flux
         "Activité Récente de l'Établissement" et l'export CSV de la
         Console Caisse. Même modèle ouvert que users/{uid}/cards : tout
         utilisateur authentifié (client ou staff) peut écrire/lire,
         car le staff n'a pas de rôle Firestore dédié pour l'instant. */
      match /activity/{entryId} {
        allow read, write: if request.auth != null;
      }
    }

    /* ── Données utilisateur : profil personnel.
          Le champ `email` (écrit par le client à la connexion, voir
          index.html → loadWallet) doit rester lisible par le staff
          pour retrouver une carte depuis la Console Caisse
          (recherche "users where email == ..." → uid). ── */
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId;

      /* Cartes de fidélité (une par commerce rejoint). Le staff en
         caisse (authentifié, mais avec un uid différent du client)
         doit pouvoir LIRE la carte pour afficher les vrais tampons
         lors d'un scan, et CRÉER la carte à la volée lors de la
         première visite (Carte Universelle → découverte du commerce). */
      match /cards/{cardId} {
        allow read, write: if request.auth != null;
      }
    }

    /* ── OTPs temporaires (code 6 chiffres) ── */
    match /otps/{email} {
      allow read, write: if request.auth == null;  /* pré-auth */
    }

    /* ── Fallback de développement : expiration 2026-07-10 ── */
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 7, 10);
    }
  }
}
